# Perfect Storm — Environment Variables
# Copy this file to .env.local for local development.
# .env.local is gitignored and should NEVER be committed.
#
# Production values go in Netlify → Site settings → Environment variables.

# ── Phase 1 (MVP) ─────────────────────────────────────────────────────────────
# No API keys required. All Phase 1 feeds are public RSS endpoints
# proxied via netlify/functions/feed.js (CORS bypass only).

# ── Phase 2 (Economic indicators) ─────────────────────────────────────────────
# FRED API — Federal Reserve economic data (CPI, rates, employment)
# Free tier available at: https://fred.stlouisfed.org/docs/api/api_key.html
VITE_FRED_API_KEY=

# Alpha Vantage — Fundamentals, earnings calendar, price data
# Free tier (25 req/day) at: https://www.alphavantage.co/support/#api-key
VITE_ALPHAVANTAGE_KEY=

# ── Phase 3 (Premium signals) ─────────────────────────────────────────────────
# GDELT GKG — ML-tagged geopolitical event stream (free, no key required)
# GDACS — Global disaster/weather alerts (free, no key required)
# OpenSanctions — Entity sanctions and risk lists (free community tier)

# ── Netlify Functions config (set in Netlify UI, not .env.local) ──────────────
# NODE_VERSION=18   (already set in netlify.toml)
